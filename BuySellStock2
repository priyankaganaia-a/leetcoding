class Solution {
    public int maxProfit(int[] prices) {
        int buy = prices[0];
        int profit = 0;
        for(int i=0; i < prices.length; i++){
            int sell = prices[i];
            if(sell < buy){
                buy = sell;
            }
            profit =  Math.max(profit, sell - buy);
        }
        return profit;
    }
}
